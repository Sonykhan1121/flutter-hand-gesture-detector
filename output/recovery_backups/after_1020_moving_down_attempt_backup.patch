+    if (baselinePalmCenter == null || baselineHandSize == null) return false;
+
+    final referenceHandSize = math.max(baselineHandSize, sample.handSize);
+    if (referenceHandSize <= 0) return false;
+
+    final maxPalmMovement =
+        referenceHandSize *
+        HandGestureThresholds.directionBentDownMaxPalmMovementRatio;
