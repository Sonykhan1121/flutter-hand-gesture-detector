+  void _updateBentDownSmoothing(
+    Map<HandLandmarkType, _NormalizedFingerPoint> currentTips,
+  ) {
+    if (_bentDownSmoothedTips.isEmpty) {
+      _bentDownSmoothedTips = Map.of(currentTips);
+      return;
+    }
+
+    final alpha = HandGestureThresholds.directionBentDownSmoothingAlpha;
+    final nextSmoothedTips = <HandLandmarkType, _NormalizedFingerPoint>{};
+
+    for (final type in HandGestureThresholds.directionFingerTipTypes) {
+      final current = currentTips[type];
+      if (current == null) continue;
+
+      final previous = _bentDownSmoothedTips[type];
+      nextSmoothedTips[type] =
+          previous == null
+              ? current
+              : _NormalizedFingerPoint(
+                x: _smoothValue(previous.x, current.x, alpha),
+                y: _smoothValue(previous.y, current.y, alpha),
+                z: _smoothValue(previous.z, current.z, alpha),
+              );
+    }
+
+    _bentDownSmoothedTips = nextSmoothedTips;
+  }
+
+  int _bentDownMovingFingerCount(
+    Map<HandLandmarkType, _NormalizedFingerPoint> baselineTips,
+    Map<HandLandmarkType, _NormalizedFingerPoint> currentTips,
+  ) {
+    var movingCount = 0;
+
+    for (final type in HandGestureThresholds.directionFingerTipTypes) {
+      final baseline = baselineTips[type];
+      final current = currentTips[type];
+      if (baseline == null || current == null) continue;
+
+      final deltaX = (current.x - baseline.x).abs();
+      final deltaY = current.y - baseline.y;
+
+      if (deltaY >= HandGestureThresholds.directionBentDownMinMotionRatio &&
+          deltaX <=
+              HandGestureThresholds.directionBentDownMaxHorizontalDriftRatio) {
+        movingCount += 1;
+      }
+    }
+
+    return movingCount;
+  }
+
+  int _bentDownResetFingerCount(
+    Map<HandLandmarkType, _NormalizedFingerPoint> baselineTips,
+    Map<HandLandmarkType, _NormalizedFingerPoint> currentTips,
+  ) {
+    var resetCount = 0;
+
+    for (final type in HandGestureThresholds.directionFingerTipTypes) {
+      final baseline = baselineTips[type];
+      final current = currentTips[type];
+      if (baseline == null || current == null) continue;
+
+      final deltaX = (current.x - baseline.x).abs();
+      final deltaY = (current.y - baseline.y).abs();
+
+      if (deltaY <= HandGestureThresholds.directionBentDownResetRatio &&
+          deltaX <=
+              HandGestureThresholds.directionBentDownMaxHorizontalDriftRatio) {
+        resetCount += 1;
+      }
+    }
+
+    return resetCount;
+  }
+
+  bool _isBentDownPalmStable(_BentDownSample sample) {
+    final baselinePalmCenter = _bentDownBaselinePalmCenter;
+    final baselineHandSize = _bentDownBaselineHandSize;
