+    final thumbPalmSideScore = _inverseLerp(
+      0.08,
+      0.25,
+      thumbSide * expectedPalmSide,
+    );
+    final confidence = (knucklePalmSideScore * 0.75 + thumbPalmSideScore * 0.25)
+        .clamp(0.0, 1.0);
+
