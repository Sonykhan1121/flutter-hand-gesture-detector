+      tipOffsets: tipOffsets,
+      palmCenter: palmCenter,
+      handSize: handSize,
+      hasBentStartPose:
+          bentStartCount >=
+          HandGestureThresholds.directionBentDownMinAlignedCount,
+      isFullyOpenLike:
+          fullyOpenLikeCount >=
+          HandGestureThresholds.directionBentDownMinAlignedCount,
+    );
+  }
