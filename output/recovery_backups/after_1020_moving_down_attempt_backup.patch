+  }) {
+    final handSize = _handSize(hand);
+    final palmCenter = geometry.palmCenter3D(hand);
+
+    if (handSize <= 0 || palmCenter == null) return null;
+
+    double visibleX(double rawX) =>
+        mirrorHorizontally ? imageSize.width - rawX : rawX;
+
+    final tipOffsets = <HandLandmarkType, _NormalizedFingerPoint>{};
+    var bentStartCount = 0;
+    var fullyOpenLikeCount = 0;
+
+    for (final chainTypes in HandGestureThresholds.directionFingerChainTypes) {
+      final chain = geometry.visibleFingerChain(hand, chainTypes);
+      if (chain == null) return null;
+
+      final mcp = chain[0];
+      final pip = chain[1];
+      final tip = chain[3];
+      final tipType = chainTypes[3];
+      final jointAngle = geometry.fingerJointAngleDegrees3D(
+        mcp: mcp,
+        pip: pip,
+        tip: tip,
