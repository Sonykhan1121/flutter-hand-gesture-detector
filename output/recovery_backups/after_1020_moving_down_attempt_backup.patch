+Hand _bentFingerDownHand({
+  double tipYOffset = 0,
+  double horizontalTipOffset = 0,
+  Offset handOffset = Offset.zero,
+  Set<int> movingFingerIndexes = const {0, 1, 2, 3},
+  Set<HandLandmarkType> missingTypes = const {},
+  Set<HandLandmarkType> lowVisibilityTypes = const {},
+  _VisibleHandSide visibleHandSide = _VisibleHandSide.palm,
+  bool fullyOpen = false,
+  GestureResult? gesture,
+}) {
+  final landmarks = <HandLandmark>[];
+  final mcps = [
+    const Offset(145, 210),
+    const Offset(180, 200),
+    const Offset(215, 205),
+    const Offset(250, 220),
+  ];
+
+  void add(HandLandmarkType type, Offset point) {
+    if (missingTypes.contains(type)) return;
+
+    landmarks.add(
+      HandLandmark(
+        type: type,
+        x: point.dx + handOffset.dx,
+        y: point.dy + handOffset.dy,
+        z: 0,
+        visibility: lowVisibilityTypes.contains(type) ? 0.2 : 1,
+      ),
+    );
+  }
+
+  for (var fingerIndex = 0; fingerIndex < _fingerChains.length; fingerIndex++) {
+    final chainTypes = _fingerChains[fingerIndex];
+    final mcp = mcps[fingerIndex];
+    final pip = mcp + const Offset(0, -45);
+    final rawTip =
+        fullyOpen ? mcp + const Offset(0, -95) : pip + const Offset(22, -31);
+    final movingOffset =
+        movingFingerIndexes.contains(fingerIndex)
+            ? Offset(horizontalTipOffset, tipYOffset)
+            : Offset.zero;
+    final tip = rawTip + movingOffset;
+    final dip = Offset.lerp(pip, tip, 0.55)!;
+
+    add(chainTypes[0], mcp);
+    add(chainTypes[1], pip);
+    add(chainTypes[2], dip);
+    add(chainTypes[3], tip);
+  }
+
+  if (visibleHandSide != _VisibleHandSide.none) {
+    add(HandLandmarkType.wrist, const Offset(160, 310));
+    add(HandLandmarkType.thumbTip, const Offset(105, 230));
+  }
+
+  return Hand(
+    boundingBox: BoundingBox.ltrb(
+      80 + handOffset.dx,
+      80 + handOffset.dy,
+      320 + handOffset.dx,
+      340 + handOffset.dy,
+    ),
+    score: 1,
+    landmarks: landmarks,
+    imageWidth: _imageSize.width.toInt(),
+    imageHeight: _imageSize.height.toInt(),
+    handedness:
+        visibleHandSide == _VisibleHandSide.back
+            ? Handedness.left
+            : Handedness.right,
+    gesture: gesture,
+  );
+}
